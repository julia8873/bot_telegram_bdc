# Plantilla para copiar en el .env real
# ejecutar "cp .env.example .env" y ya modificar el .env con toda la información

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-tu-token-de-BotFather

# BDC - conectar con REPO
BDC_PATH=./bdc
# URL del repo de la BdC. Si es privado, poner un Personal Access Token (PAT)
# de solo lectura así: https://<TOKEN>@github.com/tu-org/nombre-repo-bdc.git
BDC_REPO_URL=https://github.com/tu-org/nombre-repo-bdc.git
BDC_PULL_INTERVAL_SECONDS=300

# LLM
# CAMBIAR ESTO SEGÚN EL LLM USADO
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-tu-api-key
LLM_MODEL=gpt-4o-mini

# Número de fragmentos de /bdc que se incluyen como contexto en cada consulta
RETRIEVAL_TOP_K=4